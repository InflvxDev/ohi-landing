---
import MainHeader from '../components/MainHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Layout from '../layouts/Layout.astro';

const teamRoles = [
  'Director General',
  'Directora Médica',
  'Directora de Enfermería',
  'Director Administrativo',
];
---

<Layout>
  <MainHeader />

  <main id="inicio" class="bg-background text-text-base">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section class="quienes-hero relative overflow-hidden border-b border-primary-800 bg-link rounded-b-full md:rounded-b-[3rem]">
      <div class="absolute inset-0 quienes-grid" aria-hidden="true"></div>
      <div class="mx-auto max-w-7xl px-5 py-16 md:py-20">
        <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div class="relative z-10 hidden lg:flex items-center justify-center py-6">
            <img
              src="/logo_negativo_fondo_azul_vertical.png"
              alt="OHI — Organización Humana Integral"
              class="h-auto w-96 max-w-full object-contain drop-shadow-lg xl:w-md"
            />
          </div>

          <article class="relative z-10">
            <span class="inline-flex rounded border border-accent-400/50 bg-white/10 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.2em] text-accent-300 shadow-sm">
              Quiénes somos
            </span>
            <h1 class="mt-5 text-3xl font-black leading-tight text-white md:text-5xl">
              Institución líder en la región en servicios de salud de mediana y alta complejidad
            </h1>
            <p class="mt-6 text-base leading-7 text-white/70 md:text-lg md:leading-8">
              Brindamos atención integral de calidad, eficiente, oportuna y humanizada, con tecnología médica avanzada y un talento humano idóneo, comprometido con cada paciente.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── QUIÉNES SOMOS ──────────────────────────────────────── -->
    <section id="quienes-somos" class="mx-auto max-w-6xl px-5 py-14 md:py-16">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <article class="py-2 md:py-4 lg:pr-6">
          <h2 class="text-2xl font-extrabold text-primary-700 md:text-3xl">Quiénes Somos</h2>
          <p class="mt-5 text-base leading-7 text-text-muted">
            Nuestro principal objetivo es brindar un servicio humanizado por vocación a toda la población, ofreciendo atención diferencial con accesos especiales para urgencias adulto, urgencias maternidad, urgencias pediátricas y urgencias para pacientes politraumatizados, cada una con profesionales especializados las 24 horas.
          </p>
          <p class="mt-4 text-base leading-7 text-text-muted">
            Contamos además con unidades especializadas como la Unidad de Intervencionismo Cardiovascular de la Costa, el Banco de Sangre y el Centro de Aféresis.
          </p>
        </article>

        <div class="overflow-hidden rounded-3xl border border-primary-100 bg-white shadow-sm">
          <img
            src="/img/Quienes-somos-OHI-1.webp"
            alt="Equipo e instalaciones de Organización Humana Integral"
            class="h-auto w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <aside id="nuestra-creencia" class="nuestra-creencia-panel mx-auto mt-10 max-w-4xl p-7 text-center md:p-9">
        <h3 class="text-xs font-extrabold uppercase tracking-[0.22em] text-primary-700/80">Nuestra Creencia</h3>
        <p class="mt-4 text-xl font-semibold leading-8 text-primary-700 md:text-2xl">
          Creemos que no hay mejor cuidado para la salud como el que te hace sentir en casa.
        </p>
        <div class="mx-auto mt-5 h-1 w-20 rounded-full bg-accent-500/80"></div>
      </aside>
    </section>

    <!-- ── PROPÓSITO + DIFERENCIAL ────────────────────────────── -->
    <section class="border-y border-primary-100 bg-primary-50/40">
      <div class="mx-auto max-w-7xl px-5 py-14 md:py-16">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <article class="relative overflow-hidden rounded-2xl border border-primary-100 bg-white p-7 shadow-sm md:p-10">
            <div class="pointer-events-none absolute -right-12 -top-12 h-36 w-36 rounded-full bg-accent-200/45 blur-2xl"></div>
            <h3 id="nuestro-proposito" class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary-600">Nuestro Propósito</h3>
            <p class="mt-3 text-2xl font-extrabold leading-tight text-primary-700 md:text-3xl">
              Ser toda una familia especializada en cuidar tu salud de forma integral, con calidad humana y segura.
            </p>
            <p class="mt-5 max-w-xl text-sm leading-6 text-text-muted md:text-base">
              Construimos experiencias de atención donde la tecnología, la empatía y la seguridad trabajan juntas para proteger lo más importante: tu bienestar y el de tu familia.
            </p>
            <div class="mt-7 flex flex-wrap gap-2">
              <span class="rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">Calidad humana</span>
              <span class="rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">Atención segura</span>
              <span class="rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">Cuidado integral</span>
            </div>
          </article>

          <div>
            <h3 id="nuestro-diferencial" class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary-600">Nuestro Diferencial</h3>
            <ul class="mt-4 grid gap-3 sm:grid-cols-2">
              <li class="diferencial-card rounded-2xl px-4 py-3 text-sm">Accesos de urgencias diferenciadas.</li>
              <li class="diferencial-card rounded-xl px-4 py-3 text-sm">Integralidad en los servicios.</li>
              <li class="diferencial-card rounded-[1.1rem] px-4 py-3 text-sm">Innovación tecnológica.</li>
              <li class="diferencial-card rounded-2xl px-4 py-3 text-sm">Espíritu protector que reconoce el valor del ser humano.</li>
              <li class="diferencial-card rounded-xl px-4 py-3 text-sm">Centro materno infantil integral en la región.</li>
              <li class="diferencial-card rounded-[1.1rem] px-4 py-3 text-sm">Banco de Sangre.</li>
              <li class="diferencial-card rounded-2xl px-4 py-3 text-sm">Centro especializado de trauma.</li>
              <li class="diferencial-card rounded-xl px-4 py-3 text-sm">Central de Mezclas (Unidosis / Microdosis).</li>
              <li class="diferencial-card rounded-[1.1rem] px-4 py-3 text-sm sm:col-span-2">Buenas prácticas de elaboración.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter />
</Layout>

<style>
  .quienes-hero {
    background:
      radial-gradient(circle at 15% 20%, rgba(194, 213, 1, 0.16) 0%, rgba(194, 213, 1, 0) 34%),
      radial-gradient(circle at 88% 80%, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0) 40%),
      linear-gradient(135deg, #052e87 0%, #04256c 58%, #031c51 100%);
  }

  .quienes-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, black, transparent 85%);
  }

</style>
