            <div class={`area-copy space-y-4 text-sm leading-6 md:text-base md:leading-7 ${center.id === 'diagnostico' ? 'diagnostico-copy-panel' : ''}`}>
              {center.intro.map((paragraph) => <p>{paragraph}</p>)}
              {center.bullets && (
                <ul class="area-pills grid gap-2 sm:grid-cols-2">
                  {center.bullets.map((item) => <li>{item}</li>)}
                </ul>
              )}
              {center.outro?.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>

          {center.id === 'pediatria' ? (
            <div class="mt-12">
              <PediatricServicesModal services={center.services} />
            </div>
          ) : (
            <div class={`area-services mt-12 grid gap-5 ${center.id === 'cemic' ? 'area-services-cemic' : center.services.length > 1 ? 'lg:grid-cols-2' : ''}`}>
              {center.services.map((service, serviceIndex) => (
                <article class={`area-service ${center.id === 'diagnostico' && serviceIndex === 2 ? 'diagnostico-service-wide' : ''} ${center.id === 'mezclas' ? 'mezclas-service' : ''} ${center.id === 'cemic' ? `cemic-service ${serviceIndex % 2 === 1 ? 'cemic-service-reverse' : ''} ${service.title === 'Unidad de Cuidados Críticos Neonatal' ? 'cemic-service-featured' : ''}` : ''}`}>
                  {service.image && <img src={service.image} alt={service.title} class="area-service-image" loading="lazy" decoding="async" />}
                  <div class="area-service-body">
                    {!['Servicios', 'Servicios ofrecidos'].includes(service.title) && <p class="text-xs font-extrabold uppercase tracking-[0.16em]">Servicio</p>}
                    <h4 class="mt-2 text-xl font-black md:text-2xl">{service.title}</h4>
                    <div class="mt-4 space-y-4 text-sm leading-6">
                      {service.text?.map((paragraph) => <p>{paragraph}</p>)}
                      {service.bullets && (
                        <ul class="area-list grid gap-2 sm:grid-cols-2">
                          {service.bullets.map((item) => <li>{item}</li>)}
                        </ul>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    ))}
  </main>

  <SiteFooter />
</Layout>

