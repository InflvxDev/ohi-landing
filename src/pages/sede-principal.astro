          </p>
        </div>
      </div>
    </section>

    <section id="servicios-principales" class="scroll-mt-32 bg-background py-14 md:py-18">
      <div class="mx-auto max-w-7xl px-5">
        <div class="max-w-3xl">
          <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary-600">Portafolio asistencial</p>
