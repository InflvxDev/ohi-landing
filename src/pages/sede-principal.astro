const navItems = [
  { href: '#servicios-principales', label: 'Servicios principales' },
  { href: '#cemic', label: 'CEMIC' },
  { href: '#pediatria', label: 'Pediatría' },
  { href: '#diagnostico', label: 'Apoyo diagnóstico' },
  { href: '#unicarc', label: 'UNICARC' },
  { href: '#mezclas', label: 'Central de mezclas' },
  { href: '#endoscopica', label: 'Unidad endoscópica' },
