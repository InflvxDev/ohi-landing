---
import MainHeader from '../components/MainHeader.astro';
import PediatricServicesModal from '../components/sede-principal/PediatricServicesModal.astro';
import PrimaryServicesCarousel from '../components/sede-principal/PrimaryServicesCarousel.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Layout from '../layouts/Layout.astro';

type ServiceGroup = {
  title: string;
  items: string[];
};

type ServiceItem = {
  title: string;
  image?: string;
  text?: string[];
  label?: string;
  bullets?: string[];
  groups?: ServiceGroup[];
};

type Center = {
  id: string;
  kicker: string;
  title: string;
  theme: string;
  intro: string[];
  bullets?: string[];
  outro?: string[];
  services: ServiceItem[];
};

