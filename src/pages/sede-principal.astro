          <PrimaryServicesCarousel services={primaryServices} />
        </div>
      </div>
    </section>

    <section class="areas-intro border-y border-primary-100 bg-white">
      <div class="mx-auto grid max-w-7xl gap-8 px-5 py-14 md:py-18 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary-600">Áreas cruciales</p>
