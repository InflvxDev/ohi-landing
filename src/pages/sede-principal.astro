---

<Layout>
  <MainHeader />

  <main class="bg-background text-text-base">
    <section class="sede-hero relative min-h-[calc(100vh-76px)] overflow-hidden bg-primary-900 text-white">
      <img
        src="/img/OHI-entrada.webp"
        alt="Entrada de la Clínica OHI Sede Principal"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-linear-to-r from-primary-700/78 via-primary-500/42 to-white/8"></div>
      <div class="absolute inset-x-0 bottom-0 h-32 bg-linear-to-t from-primary-500/35 to-transparent"></div>

      <div class="relative z-10 mx-auto flex min-h-[calc(100vh-76px)] max-w-7xl flex-col justify-end px-5 py-10 md:py-14">
        <div class="grid gap-8 lg:grid-cols-[0.74fr_0.26fr] lg:items-end">
          <article class="max-w-4xl pb-4">
            <span class="inline-flex rounded-full border border-accent-400/60 bg-accent-500/12 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.22em] text-accent-200 shadow-sm backdrop-blur">
              Clínica OHI
            </span>
            <h1 class="mt-6 max-w-4xl text-5xl font-black leading-[0.95] text-white md:text-7xl lg:text-8xl">Sede Principal</h1>
            <p class="mt-7 max-w-3xl text-lg leading-8 text-white/84 md:text-xl md:leading-9">
              Somos una institución prestadora de servicios de salud reconocida en la región Caribe y nacionalmente con más 20 años de experiencia, ofreciendo servicios de mediana y alta complejidad a toda la comunidad.
            </p>
            <p class="mt-4 max-w-3xl text-base leading-7 text-white/72 md:text-lg md:leading-8">
              Actualmente nuestro crecimiento ha sido proporcionado a la población, proyectando nuestra infraestructura a mayor capacidad logística, con tecnología de punta y talento humano idóneo capacitado y comprometido con la buena atención de nuestros usuarios en todos sus servicios.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#servicios-principales" class="rounded bg-accent-500 px-5 py-3 text-sm font-extrabold text-primary-800 shadow-lg shadow-primary-950/30 transition hover:bg-accent-300 focus-visible:ring-2 focus-visible:ring-accent-300 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-900">
                Ver servicios
              </a>
              <a href="/#sedes" class="rounded border border-white/35 px-5 py-3 text-sm font-extrabold text-white transition hover:border-accent-300 hover:text-accent-200 focus-visible:ring-2 focus-visible:ring-accent-300 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-900">
                Volver a sedes
              </a>
            </div>
          </article>

          <aside class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
            <div class="border-l-4 border-accent-500 bg-white/10 p-4 backdrop-blur">
              <p class="text-3xl font-black text-accent-300">20+</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.14em] text-white/75">Años de experiencia</p>
            </div>
            <div class="border-l-4 border-accent-500 bg-white/10 p-4 backdrop-blur">
              <p class="text-3xl font-black text-accent-300">24h</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.14em] text-white/75">Urgencias adulto</p>
            </div>
            <div class="border-l-4 border-accent-500 bg-white/10 p-4 backdrop-blur">
              <p class="text-3xl font-black text-accent-300">Alta</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.14em] text-white/75">Complejidad</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <nav class="sticky top-19 z-40 border-b border-primary-700 bg-primary-500 shadow-lg shadow-primary-950/10" aria-label="Navegación de Sede Principal">
      <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto px-5 py-3">
        {navItems.map((item) => (
          <a href={item.href} class="shrink-0 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.12em] text-white transition hover:border-accent-300 hover:bg-accent-500 hover:text-primary-800 focus-visible:ring-2 focus-visible:ring-focus-ring focus-visible:ring-offset-2 focus-visible:ring-offset-primary-500">
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <section class="border-b border-primary-100 bg-primary-50/45">
      <div class="mx-auto max-w-7xl px-5 py-12 md:py-16">
        <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
