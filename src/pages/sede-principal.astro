        </p>
      </div>
    </section>

    {centers.map((center, centerIndex) => (
      <section id={center.id} class={`area-section ${center.theme} scroll-mt-36`}>
        <div class="mx-auto max-w-7xl px-5 py-16 md:py-20">
          <div class="area-head grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
            <div class="area-title-block">
              <span class="area-number">0{centerIndex + 1}</span>
              <p class="mt-5 text-xs font-extrabold uppercase tracking-[0.22em]">{center.kicker}</p>
