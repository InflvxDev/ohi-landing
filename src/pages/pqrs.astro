---
import MainHeader from '../components/MainHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Layout from '../layouts/Layout.astro';

const sedeOptions = ['Sede Principal', 'Sede Santa Isabel'];
const tipoSolicitudOptions = ['Petición', 'Queja', 'Reclamo', 'Sugerencia', 'Felicitaciones'];
const sexoOptions = ['Masculino', 'Femenino'];
const enfoqueDiferencialOptions = [
  'Víctima del conflicto armado',
  'Condición de discapacidad',
  'Afrodescendiente',
  'Indígena',
  'LGBTI',
  'Gestante',
  'Adulto mayor',
  'No aplica / prefiero no responder',
];
const hours = Array.from({ length: 24 }, (_, index) => String(index).padStart(2, '0'));
const minutes = Array.from({ length: 60 }, (_, index) => String(index).padStart(2, '0'));
---

<Layout
  title="PQRSF | Organización Humana Integral"
  description="Registra peticiones, quejas, reclamos, sugerencias o felicitaciones relacionadas con la atención de Organización Humana Integral."
  path="/pqrs"
>
  <MainHeader />

  <main id="contenido-principal" class="bg-background text-text-base">
    <section class="pqrs-hero border-b border-primary-100">
      <div class="mx-auto max-w-7xl px-5 py-14 md:py-18">
        <p class="inline-flex rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.18em] text-primary-600">
          Atención al usuario
        </p>
        <h1 class="mt-4 text-3xl font-black leading-tight text-primary-700 md:text-5xl">
          Formato de petición, queja, reclamo, sugerencia y felicitaciones
        </h1>
        <p class="mt-4 max-w-4xl text-base leading-7 text-text-muted md:text-lg md:leading-8">
          Este formulario valida la información en pantalla y no almacena ni envía datos todavía. Para radicar formalmente tu caso, usa los canales de atención indicados en esta página.
        </p>
      </div>
    </section>

    <section class="pb-16 pt-10 md:pb-20">
      <div class="mx-auto max-w-7xl px-5">
        <div id="pqrs-form-note" class="mb-6 rounded-2xl border border-accent-300 bg-accent-50 p-5 text-primary-800">
          <p class="text-sm font-extrabold uppercase tracking-[0.16em]">Radicación oficial</p>
          <p class="mt-2 text-sm leading-6">
            La radicación digital aún no está habilitada. Puedes validar que tu información esté completa y luego comunicarte con SIAU por teléfono o acercarte a la sede correspondiente.
          </p>
          <div class="mt-3 flex flex-wrap gap-3 text-sm font-bold">
            <a href="tel:+573153467668" class="rounded bg-primary-700 px-3 py-2 text-white transition hover:bg-primary-600">Llamar a SIAU</a>
            <a href="/#siau" class="rounded border border-primary-200 bg-white px-3 py-2 text-primary-700 transition hover:border-accent-500">Ver canales SIAU</a>
          </div>
        </div>

        <form id="pqrs-form" class="pqrs-form" aria-describedby="pqrs-form-note privacy-note" novalidate>
          <div class="grid gap-6">
            <section class="pqrs-block grid gap-5 md:grid-cols-12">
              <h2 class="pqrs-block-title md:col-span-12">Datos de radicación</h2>

              <div class="md:col-span-6">
                <label for="sede" class="pqrs-label">Selecciona la sede</label>
                <select id="sede" name="sede" class="pqrs-input" required>
                  <option value="">Selecciona la sede</option>
                  {sedeOptions.map((sede) => <option value={sede}>{sede}</option>)}
                </select>
              </div>

              <fieldset class="md:col-span-6">
                <legend class="pqrs-label">Tipo de solicitud</legend>
                <div class="mt-2 flex flex-wrap gap-x-5 gap-y-2 text-sm text-primary-700">
                  {tipoSolicitudOptions.map((tipo) => (
                    <label class="inline-flex items-center gap-2">
                      <input type="radio" name="tipoSolicitud" value={tipo} class="h-4 w-4 accent-primary-600" required />
                      <span>{tipo}</span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <div class="md:col-span-4">
                <label for="areaServicio" class="pqrs-label">Área / Servicio</label>
                <input id="areaServicio" name="areaServicio" type="text" class="pqrs-input" placeholder="Ej: Urgencias" required minlength="3" maxlength="120" />
              </div>

              <div class="md:col-span-4">
                <label for="fecha" class="pqrs-label">Fecha</label>
                <input id="fecha" name="fecha" type="date" class="pqrs-input" required />
              </div>

              <fieldset class="md:col-span-4">
                <legend class="pqrs-label">Hora</legend>
                <div class="mt-1 grid grid-cols-[1fr_auto_1fr] items-center gap-2">
                  <select id="hora" name="hora" class="pqrs-input" required>
                    <option value="">00</option>
                    {hours.map((hour) => <option value={hour}>{hour}</option>)}
                  </select>
                  <span class="text-lg font-extrabold text-primary-500">:</span>
                  <select id="minuto" name="minuto" class="pqrs-input" required>
                    <option value="">00</option>
                    {minutes.map((minute) => <option value={minute}>{minute}</option>)}
                  </select>
                </div>
              </fieldset>
            </section>

            <section class="pqrs-block grid gap-5 md:grid-cols-12">
              <h2 class="pqrs-block-title md:col-span-12">Datos del paciente</h2>

              <div class="md:col-span-6">
                <label for="nombrePaciente" class="pqrs-label">Nombre completo del paciente</label>
                <input id="nombrePaciente" name="nombrePaciente" type="text" class="pqrs-input" required minlength="6" maxlength="120" />
              </div>

              <fieldset class="md:col-span-6">
                <legend class="pqrs-label">Sexo</legend>
                <div class="mt-2 flex flex-wrap gap-x-8 gap-y-2 text-sm text-primary-700">
                  {sexoOptions.map((sexo) => (
                    <label class="inline-flex items-center gap-2">
                      <input type="radio" name="sexo" value={sexo} class="h-4 w-4 accent-primary-600" required />
                      <span>{sexo}</span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <div class="md:col-span-4">
                <label for="identificacion" class="pqrs-label">No. Identificación del paciente</label>
                <input id="identificacion" name="identificacion" type="text" class="pqrs-input" inputmode="text" pattern="[0-9A-Za-z .-]{5,20}" required />
              </div>

              <div class="md:col-span-4">
                <label for="edad" class="pqrs-label">Edad</label>
                <input id="edad" name="edad" type="number" class="pqrs-input" min="0" max="120" required />
              </div>

              <div class="md:col-span-4">
                <label for="email" class="pqrs-label">Email</label>
                <input id="email" name="email" type="email" class="pqrs-input" required maxlength="120" />
              </div>

              <div class="md:col-span-4">
                <label for="Dirección" class="pqrs-label">Dirección</label>
                <input id="Dirección" name="Dirección" type="text" class="pqrs-input" required minlength="6" maxlength="140" />
              </div>

              <div class="md:col-span-4">
                <label for="Teléfono" class="pqrs-label">Teléfono</label>
                <input id="Teléfono" name="Teléfono" type="tel" class="pqrs-input" inputmode="tel" pattern="[0-9+() .-]{7,20}" required />
              </div>

              <div class="md:col-span-4">
                <label for="eapb" class="pqrs-label">EAPB</label>
                <input id="eapb" name="eapb" type="text" class="pqrs-input" required minlength="2" maxlength="80" />
              </div>
            </section>

            <section class="pqrs-block grid gap-5 md:grid-cols-12">
              <h2 class="pqrs-block-title md:col-span-12">Detalle del caso</h2>

              <fieldset class="md:col-span-12">
                <legend class="pqrs-label">Enfoque diferencial</legend>
                <div class="mt-2 flex flex-wrap gap-x-5 gap-y-2 text-sm text-primary-700">
                  {enfoqueDiferencialOptions.map((item) => (
                    <label class="inline-flex items-center gap-2">
                      <input
                        type="checkbox"
                        name="enfoqueDiferencial"
                        value={item}
                        class="h-4 w-4 rounded accent-primary-600"
                      />
                      <span>{item}</span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <div class="md:col-span-12">
                <label for="Descripción" class="pqrs-label">Descripción</label>
                <textarea
                  id="Descripción"
                  name="Descripción"
                  class="pqrs-input min-h-44"
                  required
                  minlength="20"
                  maxlength="1800"
                  placeholder="Describe tu caso de forma clara para poder ayudarte mejor."
                ></textarea>
              </div>
            </section>

            <section class="pqrs-block grid gap-5 md:grid-cols-12">
              <h2 class="pqrs-block-title md:col-span-12">Datos del acompañante</h2>

              <div class="md:col-span-6">
                <label for="nombreAcompanante" class="pqrs-label">Nombre completo del acompañante</label>
                <input id="nombreAcompanante" name="nombreAcompanante" type="text" class="pqrs-input" minlength="6" maxlength="120" />
              </div>

              <div class="md:col-span-6">
                <label for="idAcompanante" class="pqrs-label">No. Identificación del acompañante</label>
                <input id="idAcompanante" name="idAcompanante" type="text" class="pqrs-input" inputmode="text" pattern="[0-9A-Za-z .-]{5,20}" />
              </div>
            </section>

            <section class="pqrs-block grid gap-3 md:grid-cols-12">
              <h2 class="pqrs-block-title md:col-span-12">Privacidad y uso de datos</h2>
              <p id="privacy-note" class="text-sm leading-6 text-text-muted md:col-span-12">
                Esta validación ocurre en tu navegador. Cuando la radicación digital esté habilitada, el tratamiento de datos se realizará conforme a la política institucional publicada por OHI.
              </p>
              <label class="inline-flex items-start gap-3 text-sm leading-6 text-primary-800 md:col-span-12">
                <input id="privacyConsent" name="privacyConsent" type="checkbox" class="mt-1 h-4 w-4 rounded accent-primary-600" required />
                <span>
                  He leído la <a href="/politicas/tratamiento-datos-personales" class="font-bold text-link underline decoration-primary-200 underline-offset-3 hover:text-link-hover">política de tratamiento de datos personales</a> y entiendo que esta versión no envía ni almacena información.
                </span>
              </label>
            </section>
          </div>

          <div class="mt-7 flex items-center gap-4">
            <button type="submit" class="inline-flex rounded bg-link px-5 py-2.5 text-sm font-extrabold text-white transition hover:bg-link-hover focus-visible:ring-2 focus-visible:ring-accent-300 focus-visible:ring-offset-2">
              Validar información
            </button>
            <p id="pqrs-status" class="text-sm text-text-muted" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<script>
  const form = document.querySelector('#pqrs-form');

  if (form instanceof HTMLFormElement) {
    const dateInput = form.querySelector('#fecha');
    const status = form.querySelector('#pqrs-status');
    const privacyConsent = form.querySelector('#privacyConsent');
    const enfoqueCheckboxes = form.querySelectorAll<HTMLInputElement>('input[name="enfoqueDiferencial"]');

    if (dateInput instanceof HTMLInputElement) {
      dateInput.max = new Date().toISOString().split('T')[0];
    }

    form.addEventListener('input', (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement) {
        target.setCustomValidity('');
      }

      if (target instanceof HTMLInputElement && target.name === 'enfoqueDiferencial') {
        enfoqueCheckboxes.forEach((checkbox) => checkbox.setCustomValidity(''));
      }

      if (target instanceof HTMLInputElement && target.name === 'privacyConsent') {
        target.setCustomValidity('');
      }
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const Descripción = form.querySelector('#Descripción');
      if (Descripción instanceof HTMLTextAreaElement) {
        const cleanLength = Descripción.value.trim().length;
        if (cleanLength < 20) {
          Descripción.setCustomValidity('La descripción debe tener al menos 20 caracteres.');
        }
      }

      const enfoqueSeleccionado = Array.from(enfoqueCheckboxes).some((checkbox) => checkbox.checked);
      if (!enfoqueSeleccionado && enfoqueCheckboxes[0] instanceof HTMLInputElement) {
        enfoqueCheckboxes[0].setCustomValidity('Selecciona al menos una opción de enfoque diferencial o No aplica.');
      }

      if (privacyConsent instanceof HTMLInputElement && !privacyConsent.checked) {
        privacyConsent.setCustomValidity('Confirma que entiendes el uso de datos antes de validar la información.');
      }

      if (!form.checkValidity()) {
        form.reportValidity();
        form.querySelector<HTMLElement>(':invalid')?.focus();
        if (status instanceof HTMLElement) {
          status.textContent = 'Revisa los campos obligatorios antes de continuar.';
        }
        return;
      }

      if (status instanceof HTMLElement) {
        status.textContent = 'Información completa. No se envió ni almacenó ningún dato; comunícate con SIAU para radicar oficialmente el caso.';
      }
    });
  }
</script>

<style>
  .pqrs-hero {
    background:
      radial-gradient(circle at 12% 14%, rgba(194, 213, 1, 0.14) 0%, transparent 32%),
      linear-gradient(180deg, #f4f6fa 0%, #ffffff 70%);
  }

  .pqrs-form {
    background:
      linear-gradient(175deg, rgba(244, 246, 250, 0.48) 0%, rgba(255, 255, 255, 0.98) 30%);
  }

  .pqrs-block {
    border: 1px solid #e6eaf3;
    border-radius: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.92);
  }

  .pqrs-block-title {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #052e87;
  }

  .pqrs-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #3d5270;
  }

  .pqrs-input {
    margin-top: 0.45rem;
    width: 100%;
    border: 1px solid #d1d9e9;
    border-radius: 0.65rem;
    background: #ffffff;
    padding: 0.7rem 0.8rem;
    font-size: 0.95rem;
    color: #162133;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .pqrs-input:focus-visible {
    outline: none;
    border-color: #6982b7;
    box-shadow: 0 0 0 3px rgba(194, 213, 1, 0.35);
  }

  @media (max-width: 640px) {
    .pqrs-block {
      padding: 0.85rem;
    }

    .pqrs-label {
      letter-spacing: 0.1em;
    }
  }
</style>
