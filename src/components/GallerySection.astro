---
const galleryItems = Array.from({ length: 6 }, (_, index) => index + 1);
---

<section id="galeria" class="bg-background py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-5">
    <div class="max-w-2xl space-y-3">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-primary-500">Galeria</p>
      <h2 class="text-3xl font-black text-primary-700 sm:text-4xl">Placeholder fotos de la clinica</h2>
      <p class="text-base leading-7 text-text-muted">
        Espacio reservado para imagenes reales de instalaciones, consultorios, equipos y zonas de atencion.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {galleryItems.map((item) => (
        <div class="grid aspect-[4/3] place-items-center rounded border border-dashed border-accent-400 bg-primary-50 text-center text-xs font-semibold uppercase tracking-[0.18em] text-primary-400">
          Placeholder foto {item}
        </div>
      ))}
    </div>
  </div>
</section>