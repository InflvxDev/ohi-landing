---
type DropdownItem = {
  label: string;
  href: string;
  detail: string;
  external?: boolean;
};

type Dropdown = {
  label: string;
  href: string;
  aria: string;
  widthClass: string;
  items: DropdownItem[];
};

type NavLink = {
  label: string;
  href: string;
};

const dropdowns: Dropdown[] = [
  {
    label: "Nosotros",
    href: "/quienes-somos",
    aria: "Submenu Nosotros",
    widthClass: "menu-md",
    items: [
      { label: "Quienes Somos", href: "/quienes-somos", detail: "Proposito, enfoque humano y equipo OHI" },
      { label: "Historia", href: "/historia", detail: "Nuestro recorrido institucional" },
      {
        label: "Linea Etica y Transparencia",
        href: "https://docs.google.com/forms/d/19h6Vr09KTRC8VyZo4wNVcelmJZ2EjU-Hfd_yk9urZKI/viewform?edit_requested=true",
        detail: "Canal externo de reporte y confianza",
        external: true,
      },
    ],
  },
  {
    label: "Sedes",
    href: "/#sedes",
    aria: "Submenu Sedes",
    widthClass: "menu-sm",
    items: [
      { label: "Sede Principal", href: "/sede-principal", detail: "Servicios y atencion integral" },
      { label: "Santa Isabel", href: "/santa-isabel", detail: "Consulta la informacion de esta sede" },
    ],
  },
  {
    label: "Politicas",
    href: "/politicas",
    aria: "Submenu Politicas",
    widthClass: "menu-lg",
    items: [
      {
        label: "Actualizacion y/o Autorizacion de Tratamiento de Datos Personales",
        href: "/politicas/actualizacion-autorizacion-tratamiento-datos-personales",
        detail: "Gestion y autorizacion de informacion personal",
      },
      {
        label: "Politica de Tratamiento de Datos Personales",
        href: "/politicas/tratamiento-datos-personales",
        detail: "Lineamientos de privacidad y proteccion",
      },
      {
        label: "Politica Publica de Participacion Social en Salud (PPPSS)",
        href: "/politicas/pppss",
        detail: "Participacion ciudadana y control social",
      },
    ],
  },
];

const navLinks: NavLink[] = [
  { label: "Servicios", href: "/#servicios" },
  { label: "Galeria", href: "/#galeria" },
  { label: "SIAU", href: "/#siau" },
];

const mobileLinks: Array<Dropdown | NavLink> = [
  dropdowns[0],
  navLinks[0],
  dropdowns[1],
  navLinks[1],
  navLinks[2],
  dropdowns[2],
];

const isDropdown = (item: Dropdown | NavLink): item is Dropdown => "items" in item;
---

<header class="group/header fixed inset-x-0 top-0 z-50 h-19 border-b border-primary-100/80 bg-background/88 shadow-[0_18px_42px_-34px_rgba(3,28,81,0.75)] backdrop-blur-xl">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-accent-400 to-transparent opacity-90"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-linear-to-r from-primary-100 via-primary-300/70 to-primary-100"></div>
  <div class="pointer-events-none absolute left-[8%] top-2 h-8 w-32 rounded-full bg-accent-300/20 blur-2xl transition duration-700 group-hover/header:translate-x-10 group-hover/header:opacity-80"></div>

  <div class="mx-auto flex h-full max-w-7xl items-center justify-between gap-5 px-5">
    <a href="/" class="header-logo group/logo" aria-label="Ir al inicio">
      <span class="absolute inset-0 rounded-2xl bg-linear-to-br from-white via-primary-50 to-accent-50 opacity-0 transition duration-300 group-hover/logo:opacity-100"></span>
      <span class="relative flex h-12 items-center rounded-2xl px-3 ring-1 ring-transparent transition duration-300 group-hover/logo:-translate-y-0.5 group-hover/logo:ring-primary-100 group-hover/logo:shadow-[0_14px_28px_-20px_rgba(3,28,81,0.8)]">
        <img src="/logo.png" alt="Logo de Organizacion Humana Integral" class="h-11 w-auto" loading="eager" decoding="async" />
      </span>
    </a>

    <nav class="hidden items-center gap-1 rounded-full border border-primary-100/80 bg-white/72 p-1 text-sm font-semibold text-text-muted shadow-[inset_0_1px_0_rgba(255,255,255,0.95)] md:flex" aria-label="Navegacion principal">
      <div class="nav-dropdown group relative" aria-label={dropdowns[0].aria}>
        <a href={dropdowns[0].href} class="nav-pill">
          {dropdowns[0].label}
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06" clip-rule="evenodd" />
          </svg>
        </a>
        <div class:list={["header-menu", dropdowns[0].widthClass]}>
          <div class="menu-panel">
            {dropdowns[0].items.map((item) => (
              <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined} class="menu-link">
                <span class="menu-link-title">{item.label}</span>
                <span class="menu-link-detail">{item.detail}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/#servicios" class="nav-pill">Servicios</a>

      <div class="nav-dropdown group relative" aria-label={dropdowns[1].aria}>
        <a href={dropdowns[1].href} class="nav-pill">
          {dropdowns[1].label}
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06" clip-rule="evenodd" />
          </svg>
        </a>
        <div class:list={["header-menu", dropdowns[1].widthClass]}>
          <div class="menu-panel">
            {dropdowns[1].items.map((item) => (
              <a href={item.href} class="menu-link">
                <span class="menu-link-title">{item.label}</span>
                <span class="menu-link-detail">{item.detail}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/#galeria" class="nav-pill">Galeria</a>
      <a href="/#siau" class="nav-pill">SIAU</a>

      <div class="nav-dropdown group relative" aria-label={dropdowns[2].aria}>
        <a href={dropdowns[2].href} class="nav-pill">
          {dropdowns[2].label}
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06" clip-rule="evenodd" />
          </svg>
        </a>
        <div class:list={["header-menu", dropdowns[2].widthClass]}>
          <div class="menu-panel">
            {dropdowns[2].items.map((item) => (
              <a href={item.href} class="menu-link">
                <span class="menu-link-title">{item.label}</span>
                <span class="menu-link-detail">{item.detail}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 text-primary-700">
      <div class="hidden items-center gap-1 sm:flex">
        <a href="https://www.instagram.com/organizacionhumanaintegral/" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Organizacion Humana Integral" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12m0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8" clip-rule="evenodd"/><path fill="currentColor" d="M18 5a1 1 0 1 0 0 2 1 1 0 0 0 0-2"/><path fill="currentColor" fill-rule="evenodd" d="M1.654 4.276C1 5.56 1 7.24 1 10.6v2.8c0 3.36 0 5.04.654 6.324a6 6 0 0 0 2.622 2.622C5.56 23 7.24 23 10.6 23h2.8c3.36 0 5.04 0 6.324-.654a6 6 0 0 0 2.622-2.622C23 18.44 23 16.76 23 13.4v-2.8c0-3.36 0-5.04-.654-6.324a6 6 0 0 0-2.622-2.622C18.44 1 16.76 1 13.4 1h-2.8c-3.36 0-5.04 0-6.324.654a6 6 0 0 0-2.622 2.622M13.4 3h-2.8c-1.713 0-2.878.002-3.778.075-.877.072-1.325.202-1.638.361a4 4 0 0 0-1.748 1.748c-.16.313-.29.761-.36 1.638C3.001 7.722 3 8.887 3 10.6v2.8c0 1.713.002 2.878.075 3.778.072.877.202 1.325.361 1.638a4 4 0 0 0 1.748 1.748c.313.16.761.29 1.638.36.9.074 2.065.076 3.778.076h2.8c1.713 0 2.878-.002 3.778-.075.877-.072 1.325-.202 1.638-.361a4 4 0 0 0 1.748-1.748c.16-.313.29-.761.36-1.638.074-.9.076-2.065.076-3.778v-2.8c0-1.713-.002-2.878-.075-3.778-.072-.877-.202-1.325-.361-1.638a4 4 0 0 0-1.748-1.748c-.313-.16-.761-.29-1.638-.36C16.278 3.001 15.113 3 13.4 3" clip-rule="evenodd"/></svg>
        </a>
        <a href="https://www.facebook.com/OrganizacionHumanaIntegral/?locale=es_LA" target="_blank" rel="noopener noreferrer" aria-label="Facebook de Organizacion Humana Integral" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M20 1a3 3 0 0 1 3 3v16a3 3 0 0 1-3 3H4a3 3 0 0 1-3-3V4a3 3 0 0 1 3-3zm0 2a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1h-5v-7h2.076a1 1 0 0 0 .949-.684l.443-1.329a.75.75 0 0 0-.712-.987H15V9c0-.5.5-1 1-1h2a1 1 0 0 0 1-1v-.686a.71.71 0 0 0-.519-.695C17.171 5.273 16 5.273 16 5.273c-2.5 0-4 1.727-4 3.227V11h-2a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1h2v7H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" clip-rule="evenodd"/></svg>
        </a>
        <a href="https://co.linkedin.com/company/ohi-organizaci%C3%B3n-humana-integral-s-a" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn de Organizacion Humana Integral" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24"><path fill="currentColor" d="M6.5 8a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3M5 10a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1zm6 9h1a1 1 0 0 0 1-1v-4.5c0-1.5 3-2.5 3-.5v5a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-6c0-2-1.5-3-3.5-3S13 10.5 13 10.5V10a1 1 0 0 0-1-1h-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1"/><path fill="currentColor" fill-rule="evenodd" d="M20 1a3 3 0 0 1 3 3v16a3 3 0 0 1-3 3H4a3 3 0 0 1-3-3V4a3 3 0 0 1 3-3zm0 2a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" clip-rule="evenodd"/></svg>
        </a>
      </div>

      <a href="https://ohi.buk.co/trabaja-con-nosotros" target="_blank" rel="noopener noreferrer" class="hidden rounded-full bg-primary-500 px-4 py-2 text-sm font-bold text-white shadow-[0_14px_26px_-18px_rgba(3,28,81,0.9)] transition duration-300 hover:-translate-y-0.5 hover:bg-primary-600 hover:shadow-[0_18px_30px_-18px_rgba(3,28,81,0.95)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring focus-visible:ring-offset-2 lg:inline-flex">
        Trabaja con Nosotros
      </a>

      <details class="mobile-menu relative md:hidden">
        <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-2xl border border-primary-100 bg-white/85 text-primary-700 shadow-sm transition hover:-translate-y-0.5 hover:border-primary-200 hover:text-primary-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring focus-visible:ring-offset-2" aria-label="Abrir menu de navegacion">
          <span class="hamburger" aria-hidden="true"></span>
        </summary>
        <div class="absolute right-0 top-[calc(100%+0.9rem)] w-[min(88vw,22rem)] overflow-hidden rounded-3xl border border-primary-100 bg-white/96 p-3 text-text-muted shadow-[0_28px_60px_-28px_rgba(3,28,81,0.75)] backdrop-blur-xl">
          <nav class="grid gap-1" aria-label="Navegacion movil">
            {mobileLinks.map((item) => (
              isDropdown(item) ? (
                <details class="mobile-section rounded-2xl bg-primary-50/60">
                  <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-bold text-primary-800">
                    {item.label}
                    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform duration-300">
                      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06" clip-rule="evenodd" />
                    </svg>
                  </summary>
                  <div class="grid gap-1 px-2 pb-2">
                    {item.items.map((subItem) => (
                      <a href={subItem.href} target={subItem.external ? "_blank" : undefined} rel={subItem.external ? "noopener noreferrer" : undefined} class="rounded-xl px-3 py-2 text-sm font-semibold text-text-muted transition hover:bg-white hover:text-primary-700">
                        {subItem.label}
                      </a>
                    ))}
                  </div>
                </details>
              ) : (
                <a href={item.href} class="rounded-2xl px-4 py-3 text-sm font-bold text-primary-800 transition hover:bg-primary-50 hover:text-primary-500">{item.label}</a>
              )
            ))}
            <a href="https://ohi.buk.co/trabaja-con-nosotros" target="_blank" rel="noopener noreferrer" class="mt-2 rounded-2xl bg-primary-500 px-4 py-3 text-center text-sm font-bold text-white transition hover:bg-primary-600">Trabaja con Nosotros</a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  .header-logo {
    position: relative;
    display: inline-flex;
    isolation: isolate;
  }

  .nav-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    overflow: hidden;
    border-radius: 9999px;
    padding: 0.625rem 0.875rem;
    transition: color 220ms ease, transform 220ms ease, background 220ms ease;
  }

  .nav-pill::before {
    content: "";
    position: absolute;
    inset: 0.25rem;
    z-index: -1;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(5, 46, 135, 0.08), rgba(194, 213, 1, 0.18));
    opacity: 0;
    transform: scaleX(0.78);
    transition: opacity 220ms ease, transform 260ms ease;
  }

  .nav-pill::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0.28rem;
    height: 0.18rem;
    width: 1.15rem;
    border-radius: 9999px;
    background: #c2d501;
    opacity: 0;
    transform: translateX(-50%) scaleX(0.35);
    transition: opacity 220ms ease, transform 260ms ease;
  }

  .nav-pill:hover,
  .nav-dropdown:focus-within .nav-pill {
    color: #052e87;
    transform: translateY(-1px);
  }

  .nav-pill:hover::before,
  .nav-pill:hover::after,
  .nav-dropdown:focus-within .nav-pill::before,
  .nav-dropdown:focus-within .nav-pill::after {
    opacity: 1;
    transform: translateX(-50%) scaleX(1);
  }

  .nav-pill:hover::before,
  .nav-dropdown:focus-within .nav-pill::before {
    transform: scaleX(1);
  }

  .header-menu {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 100%;
    z-index: 30;
    padding-top: 0.9rem;
    opacity: 0;
    transform: translateX(-50%) translateY(8px) scale(0.96);
    transform-origin: top center;
    transition: opacity 220ms ease, transform 260ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }

  .menu-sm { width: 15rem; }
  .menu-md { width: 18rem; }
  .menu-lg { width: 27rem; }

  .nav-dropdown:hover .header-menu,
  .nav-dropdown:focus-within .header-menu {
    pointer-events: auto;
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  .menu-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(193, 203, 225, 0.85);
    border-radius: 1.25rem;
    background:
      radial-gradient(circle at 12% 0%, rgba(194, 213, 1, 0.18), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(244, 246, 250, 0.94));
    padding: 0.5rem;
    box-shadow: 0 24px 55px -28px rgba(3, 28, 81, 0.8);
    backdrop-filter: blur(18px);
  }

  .menu-panel::before {
    content: "";
    position: absolute;
    inset-block: 0.75rem;
    left: 0.5rem;
    width: 0.2rem;
    border-radius: 9999px;
    background: linear-gradient(180deg, #052e87, #c2d501);
    opacity: 0.75;
  }

  .menu-link {
    position: relative;
    display: grid;
    gap: 0.18rem;
    border-radius: 0.9rem;
    padding: 0.75rem 0.85rem 0.75rem 1rem;
    transition: background 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .menu-link:hover,
  .menu-link:focus-visible {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 12px 22px -18px rgba(3, 28, 81, 0.7);
    outline: none;
    transform: translateX(3px);
  }

  .menu-link-title {
    color: #031c51;
    font-size: 0.875rem;
    font-weight: 800;
    line-height: 1.25rem;
  }

  .menu-link-detail {
    color: #566d8e;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1rem;
  }

  .social-link {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition: color 220ms ease, transform 220ms ease, background 220ms ease;
  }

  .social-link:hover,
  .social-link:focus-visible {
    background: rgba(194, 213, 1, 0.16);
    color: #052e87;
    outline: none;
    transform: translateY(-2px) rotate(-3deg);
  }

  .mobile-menu summary::-webkit-details-marker,
  .mobile-section summary::-webkit-details-marker {
    display: none;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    height: 2px;
    width: 1.1rem;
    border-radius: 9999px;
    background: currentColor;
    transition: transform 220ms ease, opacity 180ms ease;
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: "";
    position: absolute;
    left: 0;
  }

  .hamburger::before { transform: translateY(-6px); }
  .hamburger::after { transform: translateY(6px); }

  .mobile-menu[open] .hamburger { transform: rotate(45deg); }
  .mobile-menu[open] .hamburger::before { opacity: 0; transform: translateY(0); }
  .mobile-menu[open] .hamburger::after { transform: translateY(0) rotate(90deg); }
  .mobile-section[open] summary svg { transform: rotate(180deg); }

  @media (prefers-reduced-motion: reduce) {
    .nav-pill,
    .nav-pill::before,
    .nav-pill::after,
    .header-menu,
    .menu-link,
    .social-link,
    .hamburger,
    .hamburger::before,
    .hamburger::after {
      transition: none;
    }
  }
</style>