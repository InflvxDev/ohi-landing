---
type PediatricService = {
  title: string;
  image?: string;
  text?: string[];
  bullets?: string[];
};

type Props = {
  services: PediatricService[];
};

const { services } = Astro.props;
---

<div class="pediatric-services" data-pediatric-services>
  <div class="grid gap-5 md:grid-cols-3">
    {services.map((service, index) => (
      <button
        type="button"
        class="pediatric-card group text-left"
        data-pediatric-open
        data-service-index={index}
        aria-label={`Abrir detalle de ${service.title}`}
        aria-haspopup="dialog"
        aria-expanded="false"
      >
        {service.image && (
          <span class="pediatric-card-media">
            <img src={service.image} alt={service.title} loading="lazy" decoding="async" />
          </span>
        )}
        <span class="block p-5">
          <span class="text-xs font-extrabold uppercase tracking-[0.16em] text-primary-500">Servicio</span>
          <span class="mt-2 block text-xl font-black leading-tight text-primary-800 transition group-hover:text-link">{service.title}</span>
        </span>
      </button>
    ))}
  </div>

  <div class="pediatric-modal fixed inset-0 z-70 hidden items-center justify-center px-4 pb-8 pt-36" data-pediatric-modal role="dialog" aria-modal="true" aria-labelledby="pediatric-modal-title">
    <button type="button" class="pediatric-modal-backdrop absolute inset-0 bg-primary-950/62 backdrop-blur-sm" data-pediatric-close aria-label="Cerrar detalle"></button>

    <article class="pediatric-modal-panel relative max-h-[calc(100vh-11rem)] w-full max-w-5xl overflow-hidden rounded-3xl bg-white shadow-2xl shadow-primary-950/30">
      <button
        type="button"
        class="absolute right-4 top-4 z-10 grid h-10 w-10 place-items-center rounded-full bg-white/90 text-primary-800 shadow-lg transition hover:bg-accent-200 focus-visible:ring-2 focus-visible:ring-focus-ring"
        data-pediatric-close
        aria-label="Cerrar detalle"
      >
        ×
      </button>

      <div class="grid max-h-[calc(100vh-11rem)] overflow-y-auto lg:grid-cols-[0.95fr_1.05fr]">
        <img data-pediatric-image src="" alt="" class="h-72 w-full object-cover lg:h-full" loading="lazy" decoding="async" />
        <div class="p-6 md:p-8">
          <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-primary-600">Clínica de Pediatría</p>
          <h3 id="pediatric-modal-title" class="mt-3 text-3xl font-black leading-tight text-primary-800" data-pediatric-title></h3>
          <div class="mt-5 space-y-4 text-sm leading-6 text-text-muted md:text-base md:leading-7" data-pediatric-text></div>
          <ul class="mt-6 grid gap-2 sm:grid-cols-2" data-pediatric-list></ul>
        </div>
      </div>
    </article>
  </div>

  <script type="application/json" data-pediatric-payload set:html={JSON.stringify(services)} />
</div>

<script>
  const initPediatricServices = () => {
    const pediatricRoots = document.querySelectorAll<HTMLElement>('[data-pediatric-services]');

    pediatricRoots.forEach((root) => {
      if (root.dataset.pediatricServicesReady === 'true') return;
      root.dataset.pediatricServicesReady = 'true';

    const payload = root.querySelector<HTMLScriptElement>('[data-pediatric-payload]');
    const modal = root.querySelector<HTMLElement>('[data-pediatric-modal]');
    const image = root.querySelector<HTMLImageElement>('[data-pediatric-image]');
    const title = root.querySelector<HTMLElement>('[data-pediatric-title]');
    const text = root.querySelector<HTMLElement>('[data-pediatric-text]');
    const list = root.querySelector<HTMLElement>('[data-pediatric-list]');
    const openButtons = root.querySelectorAll<HTMLButtonElement>('[data-pediatric-open]');
    const closeButtons = root.querySelectorAll<HTMLButtonElement>('[data-pediatric-close]');

    if (!payload || !modal || !image || !title || !text || !list) return;

    const services = JSON.parse(payload.textContent || '[]') as Array<{
      title: string;
      image?: string;
      text?: string[];
      bullets?: string[];
    }>;

    let activeButton: HTMLButtonElement | null = null;
    let closeTimer: number | undefined;

    const getFocusableElements = () => Array.from(
      modal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((element) => !element.hasAttribute('hidden') && element.offsetParent !== null);

    const closeModal = () => {
      modal.classList.remove('is-open');
      activeButton?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';

      closeTimer = window.setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        activeButton?.focus();
      }, 260);
    };

    const openModal = (index: number, button: HTMLButtonElement) => {
      const service = services[index];
      if (!service) return;

      activeButton = button;
        activeButton.setAttribute('aria-expanded', 'true');
      image.src = service.image || '';
      image.alt = service.title;
      title.textContent = service.title;
      text.innerHTML = '';
      list.innerHTML = '';

      service.text?.forEach((paragraph) => {
        const element = document.createElement('p');
        element.textContent = paragraph;
        text.append(element);
      });

      service.bullets?.forEach((item) => {
        const element = document.createElement('li');
        element.className = 'rounded-lg border border-primary-100 bg-primary-50 px-3 py-2 text-primary-800';
        element.textContent = item;
        list.append(element);
      });

      window.clearTimeout(closeTimer);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        modal.classList.add('is-open');
      });

      modal.querySelector<HTMLButtonElement>('[data-pediatric-close]')?.focus();
    };

    openButtons.forEach((button) => {
      button.addEventListener('click', () => {
        openModal(Number(button.dataset.serviceIndex), button);
      });
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeModal));

    document.addEventListener('keydown', (event) => {
      if (modal.classList.contains('hidden')) return;

      if (event.key === 'Escape') closeModal();

      if (event.key === 'Tab') {
        const focusableElements = getFocusableElements();
        const firstElement = focusableElements[0];
        const lastElement = focusableElements[focusableElements.length - 1];

        if (!firstElement || !lastElement) return;

        if (event.shiftKey && document.activeElement === firstElement) {
          event.preventDefault();
          lastElement.focus();
        } else if (!event.shiftKey && document.activeElement === lastElement) {
          event.preventDefault();
          firstElement.focus();
        }
      }
    });
    });
  };

  document.addEventListener('astro:page-load', initPediatricServices);
  initPediatricServices();
</script>

<style>
  .pediatric-card {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(5, 46, 135, 0.16);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 16px 34px -28px rgba(3, 28, 81, 0.55);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .pediatric-card-media {
    display: block;
    height: 16.5rem;
    overflow: hidden;
    background: #e8ecf5;
  }

  .pediatric-card-media img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center;
  }

  .pediatric-card:hover {
    border-color: rgba(194, 213, 1, 0.62);
    box-shadow: 0 22px 42px -28px rgba(3, 28, 81, 0.65);
    transform: translateY(-2px);
  }

  .pediatric-modal {
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms ease;
  }

  .pediatric-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .pediatric-modal-backdrop {
    opacity: 0;
    transition: opacity 240ms ease;
  }

  .pediatric-modal.is-open .pediatric-modal-backdrop {
    opacity: 1;
  }

  .pediatric-modal-panel {
    opacity: 0;
    transform: translateY(18px) scale(0.97);
    transition:
      opacity 260ms ease,
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pediatric-modal.is-open .pediatric-modal-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .pediatric-modal,
    .pediatric-modal-backdrop,
    .pediatric-modal-panel {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .pediatric-card-media {
      height: 14rem;
    }

    .pediatric-modal {
      align-items: flex-start;
      padding-top: 6.5rem;
    }
  }
</style>